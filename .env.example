# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...
# Auth agen AT/KT: "api" (default, tagih API — WAJIB produksi) atau
# "subscription" (agen pakai kuota Claude Max via login claude — hemat API saat TESTING lokal).
# ⚠ Mode subscription HANYA untuk testing dev sendiri, BUKAN melayani banyak user (ToS).
# Sebelum pakai: jalankan `claude setup-token` (atau sudah `claude login` Max) di mesin ini.
AGENT_AUTH_MODE=api
# Opsional (mode subscription, headless): token hasil `claude setup-token`.
# CLAUDE_CODE_OAUTH_TOKEN=
# Model agen AT/KT. Default Sonnet (mutu). Testing HEMAT token → set ke Haiku.
# AGENT_MODEL=claude-haiku-4-5

# ===== Database =====
# Dev lokal (docker-compose):
DATABASE_URL=postgresql+asyncpg://audit:audit@localhost:5432/audit_v7
# Production (Fly Postgres):
# DATABASE_URL=postgresql+asyncpg://...flycast/...

# ===== App =====
APP_ENV=development
# Log setiap query SQL (debug saja). Default false.
DEBUG_SQL=false
APP_SECRET_KEY=ganti-dengan-secret-acak-32-karakter

# --- Keamanan login (B4) ---
# Proteksi brute-force jalur username+password (in-memory, per-username).
LOGIN_MAX_ATTEMPTS=5            # gagal berturut sebelum akun dikunci
LOGIN_ATTEMPT_WINDOW_MINUTES=15 # jendela waktu hitung kegagalan
LOGIN_LOCKOUT_MINUTES=15        # durasi kunci setelah max attempts
SESSION_EXPIRE_HOURS=12         # masa berlaku token sesi (habis → auto-logout)
PASSWORD_MIN_LENGTH=8           # panjang minimum password baru

APP_DATA_DIR=/data
APP_V6_PATH=/v6
APP_WIKI_PATH=/wiki
# Folder skill pengawasan (SKILL.md + references) — registry skill v7.
APP_SKILLS_PATH=/skills
# Folder template laporan standar (LHP skeleton {{...}} per jenis pengawasan).
APP_TEMPLATES_PATH=/templates
# Folder task/alur cowork (memuat *-bertahap.md = definisi gate evaluasi).
APP_TASKS_PATH=/tasks
# Vault pengetahuan penuh (Obsidian/Karpathy), read-only. Catatan di <path>/wiki/.
# Kosongkan untuk menonaktifkan fitur baca vault.
APP_VAULT_PATH=
APP_CORS_ORIGINS=http://localhost:3000,https://audit-ai-v7.vercel.app

# ===== CACM / EWS SIRUP (integrasi agent tim — C1b) =====
# Kosongkan untuk nonaktifkan integrasi live (ingest offline tetap jalan).
CACM_WEBHOOK_SECRET=
CACM_AGENT_BASE_URL=
CACM_AGENT_API_KEY=
# Otomasi C2: dari sinyal live (webhook/pull) auto-buat usulan penugasan.
# off | merah (default) | merah_kuning
CACM_AUTO_PROMOTE=merah

# ===== Digestion: fallback LLM (tier-2) =====
# OFF default → ingestion tetap deterministik/gratis/cepat. ON → untuk dokumen
# yang field kuncinya HILANG dari parser deterministik, panggil model murah (Haiku)
# atas TEKS dokumen untuk memulihkan field (selektif per dokumen, hemat token).
# Asumsi: tidak ada dokumen scan (teks selalu terbaca). Butuh ANTHROPIC_API_KEY.
DIGEST_LLM_FALLBACK=false
# Model fallback (kosongkan = default claude-haiku-4-5). Override juga via env
# ANTHROPIC_FALLBACK_MODEL (dipakai harness ujicoba).
# DIGEST_LLM_MODEL=claude-haiku-4-5-20251001

# ===== Frontend =====
NEXT_PUBLIC_API_BASE=http://localhost:8000
