# Data
backend/data/
backend/.data/
# Data penugasan riil (dokumen audit sensitif: pegawai, SOP internal, laporan
# ber-tanda tangan). JANGAN di-push ke GitHub.
/data/
*.db
*.sqlite

# Test fixtures (regenerate via dummy-test-docs/_generator.py)
dummy-test-docs/*.pdf
dummy-test-docs/*.xlsx

# Wiki copy untuk build context (di-sync dari ../wiki/ saat deploy)
backend/wiki/

# OS
.DS_Store
._*
Thumbs.db

# Dev server logs
*.log.err

# IDE
.vscode/
.idea/
.obsidian/

# TS build cache
*.tsbuildinfo

# Knowledge base eksternal (repo git terpisah — jangan di-commit ke proyek ini)
llm-wiki/

# Logs
*.log

# Backup sed
.env.bak*

# EWS SIRUP delivery tim (service terpisah; jangan vendor node_modules/.env/crawl besar)
# Root-anchored supaya tidak ikut meng-ignore frontend/app/cacm (macOS case-insensitive)
/CACM/

# Output harness ujicoba digestion
_digest-test/

# Folder test penugasan hasil render uji coba (context.md + _KKP/_LHP/_PKP).
# Artefak test, bukan source — jangan di-push.
test-*-render/

# Korpus ujicoba digestion: dokumen asli jangan di-commit (mungkin rahasia);
# struktur folder + README + golden.json tetap di-track.
digest-test-corpus/**/*.pdf
digest-test-corpus/**/*.docx
digest-test-corpus/**/*.xlsx
digest-test-corpus/**/*.doc
digest-test-corpus/**/*.xls

# Claude Code per-user (izin tool, dll. — jangan ikut ke repo)
/.claude/

# Draft skill hasil Graduasi (work-in-progress, di-promote ke knowledge/skills/<nama>/
# setelah reviu PT/PM — bukan source repo)
knowledge/skills/_draft/
